{
  "name": "dealhunter-ai-affiliate-platform",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "build": "npm --workspace apps/web run build",
    "dev:web": "npm --workspace apps/web run dev",
    "format": "prettier --check .",
